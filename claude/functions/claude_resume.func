#!/bin/bash

source "${DOTFILES}/bash/functions/log_utils.sh"

#==============================================================================
# Description: List recent Claude Code sessions (newest first) as a table, let you
#              pick one, then cd into that session's original working directory and
#              resume it. Works from anywhere — the session's cwd is read from the
#              transcript itself, not inferred from the (lossy) project dir name.
#              The table adapts its wide columns (title/dir/branch) to the terminal width.
#              Sessions open right now in a running `claude` process are flagged "live" (cyan) in
#              the Status column (Linux only — detection reads /proc).
#
# Usage: claude_resume [OPTIONS] [filter]
#
# Arguments:
#   filter - Optional substring; only sessions whose cwd contains it are shown
#
# Options:
#   -n <count>   How many recent sessions to list (default 25)
#   -h, --help   Print this message
#
# Returns:
#   0 - Resumed (or nothing to do)
#   1 - Bad usage / no claude binary / no sessions
#
# Examples:
#   claude_resume            # pick from the 25 most recent sessions
#   claude_resume spark      # only sessions whose cwd contains "spark"
#   claude_resume -n 40      # widen the list to 40
#==============================================================================
function claude_resume() {
  local __usage="
NAME:
  claude_resume - pick a recent Claude Code session, cd to its directory, and resume it

SYNOPSIS
  claude_resume [OPTIONS] [filter]

OPTIONS:
  -n <count>    Number of recent sessions to list (default 25)
  -h, --help    Prints this message

EXAMPLES:
  claude_resume
  claude_resume spark
  claude_resume -n 40
"

  local count=25
  while [[ "${1:-}" =~ ^-{1,2}.* ]]; do
    case "$1" in
      -h|--help) echo "$__usage"; return 0;;
      -n) count="$2"; shift 2;;
      *) log_error "Invalid option: \"$1\""; echo "$__usage"; return 1;;
    esac
  done
  local filter="${1:-}"

  command -v claude >/dev/null || { log_error "'claude' not found on PATH"; return 1; }

  local projects="${HOME}/.claude/projects"
  [[ -d "$projects" ]] || { log_error "No Claude projects dir at $projects"; return 1; }

  # Detect sessions currently open in a running `claude` process (Linux /proc; degrades to "no live
  # sessions" elsewhere). Two cases: `claude --resume <sid>` hands us the session id directly; a bare
  # `claude` hides it, so we pass that process's cwd through and let the Python claim the newest
  # transcript(s) launched there. (Claude appends-and-closes transcripts, so lsof/open-fd is no help.)
  local -a live_sids=() live_cwds=()
  local ps_pid ps_args ps_rest ps_cwd
  while read -r ps_pid ps_args; do
    case "$ps_args" in
      "claude --resume "*) ps_rest="${ps_args#claude --resume }"; live_sids+=("${ps_rest%% *}");;
      "claude"|"claude "*)
        ps_cwd=$(readlink "/proc/$ps_pid/cwd" 2>/dev/null) && [[ -n "$ps_cwd" ]] && live_cwds+=("$ps_cwd");;
    esac
  done < <(ps -eo pid=,args= 2>/dev/null)
  local live_cwds_str=""
  (( ${#live_cwds[@]} )) && live_cwds_str=$(printf '%s\n' "${live_cwds[@]}")

  # Emit one TSV row per session, columns:
  #   session_id \t full_cwd \t "YYYY-MM-DD HH:MM" \t status \t title \t display_cwd \t branch \t msgs \t tokens \t tlevel
  # Everything but full_cwd/tlevel is displayed; full_cwd drives the cd, tlevel ("", warn, crit)
  # drives the token-cell color. Recency is the file mtime; the rest comes from transcript contents.
  local rows
  rows=$(COUNT="$count" FILTER="$filter" PROJECTS="$projects" \
         LIVE_SIDS="${live_sids[*]:-}" LIVE_CWDS="$live_cwds_str" python3 - <<'PY'
import json, glob, os, datetime, re
from collections import Counter

count  = int(os.environ["COUNT"])
filt   = os.environ["FILTER"]
projects = os.environ["PROJECTS"]
HOME   = os.path.expanduser("~")

# Sessions the caller found open in a running `claude` process (see the bash side): an exact set of
# session ids from `--resume`, plus a count of bare `claude` launches per cwd to resolve below.
live_sids     = {s for s in os.environ.get("LIVE_SIDS", "").split() if s}
live_cwd_cnts = Counter(l for l in os.environ.get("LIVE_CWDS", "").splitlines() if l)

# There is no status flag in a transcript, so infer one from your last prompt:
#   "live" - the session is open in a running `claude` process (set below from process info, not guessed)
#   "done" - reads as approval/thanks/sign-off, the work wrapped up
#   "tbc"  - reads as "to be continued" / paused mid-flight
#   "???"  - anything else (a task, a question, or too ambiguous to call)
# Heuristics and easy to tune. STRONG_DONE_RE holds unambiguous closers that mean "done" at any
# length; DONE_RE holds weaker approval words that only count in a short message, since they often
# appear mid-task ("nice, now do X"). 'tbc' sits between the two.
STRONG_DONE_RE = re.compile(
    r"\b(close (this|it)|resolved|lgtm|ship it|all set|that'?s all|we'?re done|done here|nailed it)\b",
    re.I,
)
DONE_RE = re.compile(
    r"\b(thanks|thank you|thx|ty|perfect|great|awesome|nice|looks (good|great)|"
    r"that works|works( now| great)?|done|excellent|beautiful|amazing)\b",
    re.I,
)
TBC_RE = re.compile(
    r"\b(to be continued|tbc|wip|continue (this |it )?(later|tomorrow|next time)|"
    r"pick (this|it) (back )?up (later|tomorrow|next time)|come back to (this|it)|"
    r"pause here|let'?s pause|stop(ping)? here|finish (this |it )?(later|tomorrow)|"
    r"resume (this |it )?(later|tomorrow)|more (on this )?later|pick up where we left off|"
    r"for now|next session)\b",
    re.I,
)

def status_of(last_prompt):
    lp = (last_prompt or "").strip()
    if not lp:
        return "???"
    if STRONG_DONE_RE.search(lp):    # unambiguous closer: done regardless of length
        return "done"
    if len(lp) >= 80:                # otherwise a long prompt is treated as an ongoing task
        return "???"
    if TBC_RE.search(lp):
        return "tbc"
    if DONE_RE.search(lp):
        return "done"
    return "???"

def first_user_text(path):
    for line in open(path, errors="ignore"):
        try: d = json.loads(line)
        except: continue
        if d.get("type") != "user": continue
        msg = d.get("message", {})
        c = msg.get("content")
        if isinstance(c, str) and c.strip():
            return c
        if isinstance(c, list):
            for b in c:
                if isinstance(b, dict) and b.get("type") == "text" and b.get("text", "").strip():
                    return b["text"]
    return ""

def short_path(cwd):
    s = cwd.replace(HOME, "~", 1) if cwd.startswith(HOME) else cwd
    parts = [p for p in s.split("/") if p != ""] if s != "~" else ["~"]
    # Show at most the last two path components so long trees don't crowd the title column. The
    # final width-trimming happens in bash, where the column width adapts to the terminal.
    if len(parts) > 2:
        s = ".../" + "/".join(parts[-2:])
    return s

rows = []
for f in glob.glob(os.path.join(projects, "**", "*.jsonl"), recursive=True):
    if "/subagents/" in f:
        continue
    cwd = None; n = 0; ai_title = ""; out_tok = 0; branch = ""; last_prompt = ""
    for line in open(f, errors="ignore"):
        try: d = json.loads(line)
        except: continue
        # Use the FIRST cwd (session launch dir): that's what determines the project
        # dir where the transcript is stored, and where `claude --resume` looks for it.
        # A mid-session `cd` changes later cwd values but not the storage location.
        if d.get("cwd") and cwd is None: cwd = d["cwd"]
        if d.get("type") in ("user", "assistant"): n += 1
        # Claude writes the auto-generated session name as repeated 'ai-title' entries; keep the latest.
        if d.get("type") == "ai-title" and d.get("aiTitle"): ai_title = d["aiTitle"]
        # Sum output tokens (what Claude generated) as a rough measure of session size.
        if d.get("type") == "assistant":
            out_tok += (d.get("message", {}).get("usage", {}) or {}).get("output_tokens", 0)
        # Keep the latest git branch seen (where the session left off).
        if d.get("gitBranch"): branch = d["gitBranch"]
        # Keep the latest recorded user prompt (used to guess whether the session is "done").
        if d.get("type") == "last-prompt" and d.get("lastPrompt"): last_prompt = d["lastPrompt"]
    if not cwd:
        continue
    if filt and filt not in cwd:
        continue
    mtime  = datetime.datetime.fromtimestamp(os.path.getmtime(f))
    sid    = os.path.basename(f)[:-6]  # strip .jsonl
    full   = cwd.replace(HOME, "~", 1) if cwd.startswith(HOME) else cwd
    tok    = f"{out_tok/1000:.0f}k" if out_tok >= 1000 else str(out_tok)
    tlevel = "crit" if out_tok > 200_000 else "warn" if out_tok > 100_000 else ""
    status = status_of(last_prompt)
    # Generous safety caps only; bash trims title/branch/dir to the width-adaptive columns.
    branch = branch[:120]
    title  = " ".join((ai_title or first_user_text(f)).split())[:120]
    rows.append((mtime, sid, cwd, full, status, title, short_path(cwd), branch, n, tok, tlevel))

rows.sort(key=lambda r: r[0], reverse=True)   # newest first (top of the list)

# Resolve which sessions are live. `--resume` ids match exactly; for each bare-launch cwd, claim the
# N newest transcripts launched there (N = bare `claude` processes sharing that cwd), skipping any
# already matched exactly. rows are newest-first, so the first matches per cwd are the freshest.
live = set(live_sids)
for cwd_target, cnt in live_cwd_cnts.items():
    claimed = 0
    for r in rows:
        if claimed >= cnt:
            break
        if r[2] == cwd_target and r[1] not in live:
            live.add(r[1]); claimed += 1

for mtime, sid, rawcwd, full, status, title, disp, branch, n, tok, tlevel in rows[:count]:
    # A sign-off wins over "live": if your last prompt reads as done, show "done" even when the
    # process is still open (you finished but left the tab up). Otherwise a running process is "live".
    if sid in live and status != "done":
        status = "live"
    print(f"{sid}\t{full}\t{mtime:%Y-%m-%d %H:%M}\t{status}\t{title}\t{disp}\t{branch}\t{n}\t{tok}\t{tlevel}")
PY
)

  if [[ -z "$rows" ]]; then
    log_error "No matching sessions found${filter:+ for filter \"$filter\"}"
    return 1
  fi

  # Styling — only when writing to a terminal, so piped/redirected output stays clean.
  local zebra="" reset="" bold="" cols=120
  if [[ -t 1 ]]; then
    zebra=$'\033[48;5;236m'   # subtle background for alternating rows
    reset=$'\033[0m'
    bold=$'\033[1m'
  fi
  # Terminal width drives the flexible columns. Prefer $COLUMNS (kept current by bash), fall back to
  # `tput cols`, then a sane default; clamp so a tiny window still yields a usable layout.
  cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 120)}
  [[ "$cols" =~ ^[0-9]+$ ]] || cols=120
  (( cols < 90 )) && cols=90

  # Fixed columns are #:3 when:16 status:6 msgs:5 tokens:6; with the eight ' │ '/' ' separators that
  # leaves this much overhead. The rest is shared by the three flexible columns (title/dir/branch).
  local overhead=58
  local flex=$(( cols - overhead ))
  local tw=$(( flex * 45 / 100 ))   # title
  local dw=$(( flex * 27 / 100 ))   # directory
  local bw=$(( flex - tw - dw ))    # branch
  (( tw < 24 )) && tw=24; (( tw > 80 )) && tw=80
  (( dw < 16 )) && dw=16; (( dw > 60 )) && dw=60
  (( bw < 14 )) && bw=14; (( bw > 60 )) && bw=60

  # Load rows into parallel arrays. metas holds every cell EXCEPT the leading number and the trailing
  # tokens cell (both handled in the print loop). exts holds the per-row count of zero-width bytes
  # baked into metas (green 'done' escape + multi-byte '…' from truncation) so the zebra pad can
  # account for them. toks/tlevels feed the token coloring.
  local -a sids cwds metas toks tlevels exts
  local sid full when status title disp branch msgs tok tlevel scell ext
  while IFS=$'\t' read -r sid full when status title disp branch msgs tok tlevel; do
    sids+=("$sid")
    cwds+=("$full")
    toks+=("$tok")
    tlevels+=("$tlevel")
    ext=0
    # Width-trim the flexible columns: title/branch keep the head, directory keeps the tail (leaf).
    (( ${#title}  > tw )) && { title="${title:0:tw-1}…";                 ext=$(( ext + 2 )); }
    (( ${#branch} > bw )) && { branch="${branch:0:bw-1}…";               ext=$(( ext + 2 )); }
    (( ${#disp}   > dw )) && { disp="…${disp:${#disp}-dw+1}";            ext=$(( ext + 2 )); }
    # Status cell: cyan "live", green "done", yellow "tbc" (fg 39 restores default without clearing zebra bg).
    local scolor=""
    if [[ -n "$reset" ]]; then
      case "$status" in
        live) scolor=$'\033[38;5;51m';;    # cyan
        done) scolor=$'\033[38;5;40m';;    # green
        tbc)  scolor=$'\033[38;5;226m';;   # yellow
      esac
    fi
    if [[ -n "$scolor" ]]; then
      printf -v scell '%s%-6s\033[39m' "$scolor" "$status"
      ext=$(( ext + ${#scolor} + 5 ))     # color escape + '\033[39m' (5), both zero-width
    else
      printf -v scell '%-6s' "$status"
    fi
    metas+=("$(printf '%-16s │ %s │ %-*s │ %-*s │ %-*s │ %5s' \
      "$when" "$scell" "$tw" "$title" "$dw" "$disp" "$bw" "$branch" "$msgs")")
    exts+=("$ext")
  done <<< "$rows"

  local size=${#sids[@]}
  log_info "Found $size session(s) (most recent first, ${cols}-col terminal):"
  echo

  # Build a horizontal rule matching the column widths: a run of '─' per cell, joined with '┼'.
  local dashes='' k
  for ((k = 0; k < 90; k++)); do dashes+='─'; done
  local rule
  rule="${dashes:0:5}┼${dashes:0:18}┼${dashes:0:8}┼${dashes:0:tw+2}┼${dashes:0:dw+2}┼${dashes:0:bw+2}┼${dashes:0:7}┼${dashes:0:7}"

  # Header + top rule.
  # shellcheck disable=SC2059
  printf "${bold} %3s │ %-16s │ %-6s │ %-*s │ %-*s │ %-*s │ %5s │ %6s${reset}\n" \
    "#" "When" "Status" "$tw" "Title" "$dw" "Directory" "$bw" "Branch" "Msgs" "Tokens"
  printf '%s\n' "$rule"

  # Data rows, zebra-striped, with the tokens cell colored orange (>100k) / red (>200k). Each row
  # carries seven multi-byte '│' dividers (3 bytes, 1 column each) plus any zero-width escapes baked
  # into metas (exts) and the token color. Pad the striped rows to cols + those extra bytes so the
  # background reaches the true terminal width. '\033[39m' restores the default fg without clearing
  # the zebra bg.
  local i line num tcolor tokcell extra
  for i in "${!sids[@]}"; do
    num=$(( i + 1 ))
    tcolor=""; extra=$(( 14 + ${exts[$i]} ))
    if [[ -n "$reset" ]]; then
      case "${tlevels[$i]}" in
        crit) tcolor=$'\033[38;5;196m';;
        warn) tcolor=$'\033[38;5;208m';;
      esac
    fi
    if [[ -n "$tcolor" ]]; then
      printf -v tokcell '%s%6s\033[39m' "$tcolor" "${toks[$i]}"
      extra=$(( extra + ${#tcolor} + 5 ))
    else
      printf -v tokcell '%6s' "${toks[$i]}"
    fi
    line=$(printf ' %3s │ %s │ %s' "$num" "${metas[$i]}" "$tokcell")
    if [[ -n "$zebra" && $(( i % 2 )) -eq 1 ]]; then
      printf '%s%-*s%s\n' "$zebra" "$(( cols + extra ))" "$line" "$reset"
    else
      printf '%s%s\n' "$line" "$reset"
    fi
  done
  echo

  local number
  while :; do
    read -r -p "Session to resume (1-$size, q to quit): " number
    [[ "$number" == "q" ]] && return 0
    [[ "$number" =~ ^[0-9]+$ ]] && (( number >= 1 && number <= size )) && break
    log_error "Enter a number between 1 and $size (or q)"
  done

  local idx=$(( number - 1 ))
  local sid="${sids[$idx]}"
  local target="${cwds[$idx]/#\~/$HOME}"   # re-expand leading ~

  if [[ ! -d "$target" ]]; then
    log_warn "Directory '$target' no longer exists; resuming from \$PWD ($PWD)"
  else
    cd "$target" || { log_error "Could not cd to $target"; return 1; }
  fi

  log_info "Resuming $sid in $(pwd)"
  claude --resume "$sid"
}

export -f claude_resume
