{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash",
      "Edit",
      "Write",
      "Edit(/home/adevore/.claude/projects/**/memory/**)",
      "Write(/home/adevore/.claude/projects/**/memory/**)"
    ],
    "defaultMode": "dontAsk"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude update 2>/dev/null || true",
            "statusMessage": "Checking for updates...",
            "async": true
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-session-start.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/notify-done.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  },
  "theme": "dark-daltonized",
  "editorMode": "vim",
  "verbose": true,
  "autoCompactEnabled": false,
  "extraKnownMarketplaces": {
    "indeed-ai-marketplace": {
      "source": {
        "source": "git",
        "url": "git@code.corp.indeed.com:ai4dp/indeed-ai-marketplace.git"
      }
    }
  }
}
